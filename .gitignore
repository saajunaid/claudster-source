# Build output (generated by export_runtime_resources.py)
dist/
runtime-resources/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node (build tooling for the extension bundlers)
node_modules/

# Extension mirror repos (junai / junai-vscode / ptarmigan / liffey) — separate GitHub repos placed
# here as working copies at cutover (Phase 4). Never tracked by claudster-source. sync.ps1 resolves
# them at $REPO_ROOT/vscode-extensions and drives their bundlers via JUNAI_SOURCE.
vscode-extensions/

# Secrets — MUST never be committed to the public repo
*.key
*.pat
.env
.env.*
!.env.example
.mcpregistry_*
github-pat.md

# Claudster runtime/local state
.claudster/usage-log.jsonl
.claudster/.last-usage-review
.claudster/memory.jsonl
.claudster/reviews/*.html
.claudster/relay.md

# OS
.DS_Store
Thumbs.db
nul
